!data/sample/
!data/sample/**

# Local config with paths / optional keys
config/settings.local.yaml
.env

# Generated figures / result tables (regenerated by the viz + ml stages)
docs/figures/
docs/results/

# Reports / large binaries kept out of the repo
*.pdf
ST5011CEM_BuildSpec.md

# OS / editor
.DS_Store
.idea/
